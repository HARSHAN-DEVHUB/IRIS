# FRIDAY Assistant Configuration - COMPLETELY FREE & OPEN-SOURCE
# No paid API keys required!

# ===== LOCAL LLM (Ollama) =====
# Download Ollama: https://ollama.ai
# Run: ollama pull mistral (or llama2, neural-chat, etc.)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ===== VOICE (All Free & Offline) =====
# Whisper (speech-to-text) - already included, fully free
WHISPER_MODEL=base

# Piper TTS (text-to-speech) - free, open-source
# Available voices: en_US-amy-medium, en_US-john-medium, etc.
PIPER_VOICE=en_US-amy-medium
PIPER_DATA_DIR=./piper_data

# Voice Activity Detection - free alternative to paid wake word
USE_VAD=true  # Voice Activity Detection instead of wake word

# ===== OPTIONAL FREE SERVICES =====
# News - use RSS feeds (free) instead of NewsAPI
NEWS_SOURCES=bbc,cnn,techcrunch

# Weather - OpenWeatherMap FREE tier
# Sign up free: https://openweathermap.org/api (5 day forecast free)
OPENWEATHER_API_KEY=optional_free_tier
OPENWEATHER_CITY=New York

# Web Search - DuckDuckGo (free, no key needed)
SEARCH_ENGINE=duckduckgo

# ===== SYSTEM CONFIG =====
FRIDAY_NAME=FRIDAY
LOG_LEVEL=INFO
DATABASE_PATH=./data/friday.db

